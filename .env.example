ANTHROPIC_API_KEY=sk-ant-your-key-here

# Guards POST /trigger. Leave unset for local dev (no auth enforced).
# Required before deploying publicly — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
TRIGGER_API_KEY=

# Shared secret for verifying signed requests to POST /webhook/github.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=

# --- Docker Compose only (not needed for local dev) ---

# Absolute path to the repo root on the HOST machine.
# Required so sandbox containers (spawned via Docker socket) can mount workspaces.
# Example: HOST_PROJECT_ROOT=/home/ubuntu/code-healer
HOST_PROJECT_ROOT=

# Host port the frontend container binds to. Only needed if port 80 is already
# taken on the host (e.g. by another site's reverse proxy) — point that proxy's
# subdomain at this port instead. Defaults to 80 if unset.
FRONTEND_PORT=
